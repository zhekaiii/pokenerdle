{
  "name": "pokenerdle",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "fe-dev": "pnpm --filter @pokenerdle/frontend dev",
    "be-dev": "cd backend && bun run dev",
    "dev": "concurrently \"pnpm fe-dev\" \"bun run be-dev\"",
    "fe-build": "pnpm --filter @pokenerdle/frontend build",
    "be-build": "pnpm --filter @pokenerdle/backend build",
    "shared-build": "pnpm --filter @pokenerdle/shared build",
    "build": "pnpm shared-build && concurrently \"pnpm be-build\" \"pnpm fe-build\"",
    "heroku-cleanup": "posthog-cli sourcemap inject --directory ./frontend/dist/assets && posthog-cli sourcemap upload --directory ./frontend/dist/assets --delete-after",
    "start": "pnpm --filter @pokenerdle/backend start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "shared",
    "frontend",
    "backend"
  ]
}
