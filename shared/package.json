{
  "name": "@pokenerdle/shared",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./daily": {
      "types": "./dist/daily/index.d.ts",
      "default": "./dist/daily/index.js"
    },
    "./pokemon": {
      "types": "./dist/pokemon/index.d.ts",
      "default": "./dist/pokemon/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "daily": [
        "./dist/daily/index.d.ts"
      ],
      "utils": [
        "./dist/utils/index.d.ts"
      ]
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.1.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "zod": "^4.0.16"
  }
}
